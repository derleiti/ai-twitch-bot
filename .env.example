
#############################################
# Zephyr Bot – .env.example (Gemini/Mistral + Ollama Fallback)
#############################################

########## Basis / Features ##########
BOT_NAME=zephyr
ENABLE_TWITCH=true
ENABLE_YOUTUBE=false
ENABLE_VISION=true
# Suppress automatic Twitch posts (vision/autonomous). Still connects for commands.
TWITCH_SILENT_AUTO=false
# Autostart a one-time vision post right after Twitch JOIN ready
AUTO_VISION_ON_START=true
STARTUP_VISION_DELAY_SEC=3
# Ignore live status for the auto-vision at startup
AUTO_VISION_IGNORE_LIVESTATUS=true

########## Priorität & Modus ##########
# Reihenfolge der Provider
AI_ORDER=gemini,mistral,gpt-oss
# "first" = erster funktionierender Provider
# "hybrid" = befrage gemini & mistral und nimm die klarste Antwort
AI_MODE=first

########## Gemini ##########
# API-Key aus Google AI Studio
GEMINI_API_KEY=YOUR_GEMINI_KEY
# Text + Vision
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

########## Mistral ##########
MISTRAL_API_KEY=YOUR_MISTRAL_KEY
MISTRAL_MODEL=mistral-large-latest
# Optional: eigenes Gateway (lassen, wenn unsicher)
# MISTRAL_API_BASE=https://api.mistral.ai

########## GPT-OSS / Ollama (lokal) ##########
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:latest
OLLAMA_TEXT_MODEL=gpt-oss:latest
VLM_MODEL=llava:latest

########## Generation Defaults ##########
MAX_NEW_TOKENS=512
TEMPERATURE=0.2
# Maximum characters for LLM responses used in comments
LLM_MAX_OUTPUT_CHARS=420

########## Pfade ##########
SCREENSHOT_DIR=/root/zephyr/screenshots
SCREENSHOT_MAX=100
# Kennzeichnung der Screenshot-Quelle (z.B. Hostname des Capture-Rechners)
VISION_SOURCE_LABEL=screen@workstation
# Vision-Event-Korrelation (Sekundenfenster; optional)
VISION_EVENT_CORROBORATION_SEC=6
# Maximum characters when vision falls back to raw text (non-JSON)
VISION_FALLBACK_MAX_CHARS=420
# Language for vision output (de or en)
VISION_LANG=de
# Language for commentary/writer output (de or en)
COMMENTARY_LANG=de
\n########## Writer Fallback ##########
# Use Qwen-based vision summary if external LLM writer chain fails
FALLBACK_USE_QWEN_SUMMARY_ON_WRITER_FAIL=true
# Default sentence if everything fails
FALLBACK_DEFAULT_SENTENCE_DE=Kurzer Blick auf den Bildschirm: Szene wird ausgewertet und zusammengefasst.

########## Auth / SSO ##########
# Öffentliche Basis-URL deiner Seite (für Redirects/Links)
SITE_URL=https://example.com
# Basis-URL des Auth-Services
AUTH_BASE_URL=http://localhost:8088
# JWT
JWT_SECRET=CHANGE_ME_TO_32+_RANDOM_CHARS
JWT_ISS=https://auth.ailinux.local
JWT_AUD=ailinux
JWT_TTL_SECONDS=3600
COOKIE_SECURE=true   # set to false for localhost over plain http

# Google OIDC
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# WordPress OIDC/OAuth (bevorzugt Discovery)
WP_WELL_KNOWN=https://your-wp.example/.well-known/openid-configuration
# WP OIDC Client
WP_CLIENT_ID=YOUR_WP_CLIENT_ID
WP_CLIENT_SECRET=YOUR_WP_CLIENT_SECRET
# Falls kein Discovery verfügbar, statische Endpunkte:
# WP_ISS=https://your-wp.example
# WP_AUTH_URL=https://your-wp.example/oauth/authorize
# WP_TOKEN_URL=https://your-wp.example/oauth/token
# WP_USERINFO_URL=https://your-wp.example/oauth/userinfo

# Auth-DB (SQLite)
AUTH_DB_PATH=./auth.db

########## Twitch ##########
# Twitch-Chat Konfiguration (für IRC-Verbindung)
# Benutzername des Bots (Twitch-Loginname)
TWITCH_USERNAME=your_bot_username
# OAuth-Token im Format 'oauth:xxxxxxxxxxxxxxxx' (unter https://twitchapps.com/tmi/ generierbar)
TWITCH_OAUTH_TOKEN=oauth:REPLACE_ME
# Kanalname (ohne oder mit '#')
TWITCH_CHANNEL=your_channel
# Optional: IRC-Host/Port und Längenlimit
TWITCH_IRC_HOST=irc.chat.twitch.tv
TWITCH_IRC_PORT=6697
TWITCH_MAX_MESSAGE_LEN=500
# Send the one-time greeting message on connect
TWITCH_SEND_HELLO=true
# Optional: custom greeting text on connect (bypasses budgets)
TWITCH_HELLO_TEXT=zephyrt bot online · Befehle: !links, !shots, !shot, !askshot, !bild, !witz, !health, !budget

# Periodic help/commands announcement
TWITCH_HELP_ENABLED=true
TWITCH_HELP_INTERVAL_SEC=300
# Leave empty to use the default list used by !info
# TWITCH_HELP_MESSAGE=Befehle: !links, !shots [n], !shot <latest|sid>, !askshot <latest|sid> <frage>, !bild (Analyse), !witz (kurzer Witz), !health, !budget

########## Commentary/Chat ##########
# Präfix am Zeilenanfang (max 1 Emoji empfohlen)
POST_PREFIX=🎯 Vision
# Host/Source im Prefix anzeigen (z. B. "🎯 Vision [zephyr-host|screen@workstation]")
SHOW_HOST_IN_PREFIX=true
# Optional: explizite Host-Bezeichnung (Fallback: System-Hostname)
VISION_HOST_LABEL=
# Dedupe-Fenster (Sekunden) für Ereignis-Signaturen (event|route|port)
COMMENT_SIGNATURE_WINDOW=30

########## Cooldowns & Gating ##########
# Globaler Mindestabstand zwischen beliebigen Chat-Posts (Nightbot-ähnlich)
CHAT_GLOBAL_COOLDOWN_SEC=120
# "Keine relevanten Objekte erkannt" nur posten, wenn seit N Sekunden nichts gesendet wurde
NORELEVANT_MIN_INTERVAL_SEC=90
# Cross-Host De-Priorisierung: Nur selten posten, wenn Quelle nicht zu diesem Host passt
# (Match, wenn dieser Filter-String in Host oder Source vorkommt; leer = aus)
VISION_HOST_FILTER=
CROSS_HOST_DEPRIORIZE_SEC=120

########## Health ##########
# per-endpoint timeout in milliseconds
HEALTH_TIMEOUT_MS=1500
# toggle individual checks
HEALTH_INCLUDE_QWEN=true
HEALTH_INCLUDE_AUTH=true
# include short error tags like (timeout) when a check fails
HEALTH_SHOW_ERRORS=false
HEALTH_INCLUDE_IRC=true
HEALTH_IRC_TIMEOUT_MS=800
HEALTH_IRC_MIN_GAP_S=5

# optional: Link-Sammlung fürs Chat-Kommando !links
LINKS_URL=https://linktr.ee/derleiti

########## Random Chat Replies ##########
# Enable random short replies to user chat messages (default: false)
TWITCH_RANDOM_REPLY=false
# Probability per eligible message (0.0–1.0)
TWITCH_RANDOM_REPLY_RATE=0.10
# Minimum seconds between any two random replies
TWITCH_RANDOM_REPLY_MIN_GAP_SEC=90
# Ignore replies for these usernames (comma-separated, case-insensitive)
TWITCH_RANDOM_REPLY_IGNORE_USERS=nightbot,streamelements,moobot,anotherttvviewer

########## Chat Post Budget ##########
# Aktiviert globales Chat-Posting-Limit (empfohlen: true)
POST_BUDGET_ENABLED=true
# Fenster in Sekunden (z. B. 10 Minuten)
POST_BUDGET_WINDOW_SEC=600
# Max. Nachrichten pro Fenster
POST_BUDGET_MAX_MSGS=6
# true = still übers Limit droppen; false = seltene Hinweiszeile senden
POST_BUDGET_SILENT=true
# Cooldown in Sekunden für Hinweiszeile (nur wenn SILENT=false)
POST_BUDGET_NOTICE_COOLDOWN_SEC=60

########## Bucket Budgets (optional, zusätzlich zum globalen Limit) ##########
# Kommagetrennt: bekannte Buckets
POST_BUDGET_BUCKETS=vision,command,system,startup_vision,default

# Vision (Stream-Autoposts)
POST_BUDGET_VISION_WINDOW_SEC=600
POST_BUDGET_VISION_MAX_MSGS=4
\n# Startup vision (one-time at connect)
POST_BUDGET_STARTUP_VISION_WINDOW_SEC=30
POST_BUDGET_STARTUP_VISION_MAX_MSGS=2

# Command (Antworten auf !health, !links, !shots, etc.)
POST_BUDGET_COMMAND_WINDOW_SEC=120
POST_BUDGET_COMMAND_MAX_MSGS=6

# System (Fehler/Hinweise)
POST_BUDGET_SYSTEM_WINDOW_SEC=300
POST_BUDGET_SYSTEM_MAX_MSGS=3

# Default (Fallback, wenn kein Bucket angegeben/erkannt)
POST_BUDGET_DEFAULT_WINDOW_SEC=600
POST_BUDGET_DEFAULT_MAX_MSGS=6

# Notfälle dürfen Budget umgehen (nur sehr sparsam nutzen)
POST_BUDGET_ALLOW_PRIORITY=true

# !health: Bucket-Statuszeile anhängen?
HEALTH_INCLUDE_BUCKETS=true

# --- Budget command (chat) ---
BUDGET_CMD=budget
BUDGET_REQUIRE_MOD=true

########## Empfohlene Tuning-Optionen (Vision alle ~10s) ##########
# Aktiv lassen: Twitch-Posting und nicht stumm
# ENABLE_TWITCH=true
# TWITCH_SILENT_AUTO=false

# AntiFlood (Default 8s – kann in Produktion höher sein)
# SHORT_CHAT_MIN_INTERVAL=8

# Vision-Bucket großzügig (z. B. 12 Nachrichten pro 60s)
# POST_BUDGET_ENABLED=true
# POST_BUDGET_BUCKETS=vision,command,system,default
# POST_BUDGET_VISION_WINDOW_SEC=60
# POST_BUDGET_VISION_MAX_MSGS=12

# Optional: globales Budget großzügiger
# POST_BUDGET_WINDOW_SEC=300
# POST_BUDGET_MAX_MSGS=60

# Debug: sichtbare Hinweise + ausführliche Logs
# POST_BUDGET_SILENT=false
# LOG_LEVEL=DEBUG

# AntiFlood-Salting gegen "identisch"-Erkennung bei ähnlichen Sätzen
# POST_SALT=.vision
